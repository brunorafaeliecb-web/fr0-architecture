{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_id",
    "registry_version",
    "architecture_baseline_id",
    "status",
    "risks"
  ],
  "properties": {
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "registry_version": {
      "type": "integer",
      "const": 1
    },
    "architecture_baseline_id": {
      "type": "string",
      "const": "AB-FR0-001"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "APPROVED"
      ]
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_id",
          "name",
          "severity",
          "treatment",
          "owner",
          "status"
        ],
        "properties": {
          "risk_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "treatment": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$id": "urn:fr0:schema:risk:v1"
}
