{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_id",
    "registry_version",
    "architecture_baseline_id",
    "status",
    "controls"
  ],
  "properties": {
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "registry_version": {
      "type": "integer",
      "const": 1
    },
    "architecture_baseline_id": {
      "type": "string",
      "const": "AB-FR0-001"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "APPROVED"
      ]
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "canonical_name",
          "invariants",
          "semantic_owner",
          "priority",
          "status",
          "failure_behavior"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "minLength": 1
          },
          "canonical_name": {
            "type": "string",
            "minLength": 1
          },
          "invariants": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "semantic_owner": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "failure_behavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
