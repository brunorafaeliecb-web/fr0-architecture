{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_id",
    "registry_version",
    "architecture_baseline_id",
    "status",
    "facts"
  ],
  "properties": {
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "registry_version": {
      "type": "integer",
      "const": 1
    },
    "architecture_baseline_id": {
      "type": "string",
      "const": "AB-FR0-001"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "APPROVED"
      ]
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fact_id",
          "canonical_name",
          "semantic_owner",
          "transition_owner",
          "priority"
        ],
        "properties": {
          "fact_id": {
            "type": "string",
            "minLength": 1
          },
          "canonical_name": {
            "type": "string",
            "minLength": 1
          },
          "semantic_owner": {
            "type": "string",
            "minLength": 1
          },
          "transition_owner": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "canonical_name",
          "decision_owner",
          "inputs"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 1
          },
          "canonical_name": {
            "type": "string",
            "minLength": 1
          },
          "decision_owner": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
